# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postcode Lookup (Optional - uses postcodes.io free tier if not set)
IDEAL_POSTCODES_API_KEY=

# Cron Jobs
CRON_SECRET=

# Admin Contact
NEXT_PUBLIC_ADMIN_PHONE=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@ampleremovals.com
RESEND_ADMIN_EMAIL=admin@ampleremovals.com

# SMS & WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
# Twilio Content SID for the lead-invite WhatsApp template (set after Meta
# approves `lead_details_request`; blank = free-text fallback).
WHATSAPP_LEAD_DETAILS_SID=

# Payments (Stripe)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Quote Confirmation (generate a random 32+ character string)
QUOTE_CONFIRM_SECRET=

# Deposit / bank transfer (shown to the customer on the deposit screen)
NEXT_PUBLIC_BANK_ACCOUNT_NAME=
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=
NEXT_PUBLIC_BANK_SORT_CODE=
NEXT_PUBLIC_DEPOSIT_PERCENTAGE=25
