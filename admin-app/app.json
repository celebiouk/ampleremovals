{
  "expo": {
    "name": "Ample Admin",
    "slug": "ample-admin-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ampleadmin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#6b21a8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ampleremovals.admin"
    },
    "android": {
      "package": "com.ampleremovals.admin"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
