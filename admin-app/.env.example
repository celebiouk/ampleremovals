# Copy to .env and fill in. These are the SAME public values as the web app.
# Public (anon) values only — NEVER put the Supabase service-role key here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the deployed Next.js app whose /api/admin/** routes we reuse.
# e.g. https://www.ampleremovals.com
EXPO_PUBLIC_SITE_URL=
